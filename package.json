{
  "name": "aboutyou-private-catalog",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev --workspace @catalog/web",
    "dev:web:real": "npm run dev:real --workspace @catalog/web",
    "dev:web:real-db": "npm run dev:real-db --workspace @catalog/web",
    "dev:api": "npm run dev --workspace @catalog/api",
    "dev:api:real-db": "npm run dev:real-db --workspace @catalog/api",
    "sync": "npm run sync --workspace @catalog/sync",
    "sync:metadata": "npm run sync:metadata --workspace @catalog/sync",
    "verify:catalog:staging": "npm run verify:catalog:staging --workspace @catalog/sync",
    "test": "vitest run",
    "test:live:metadata": "vitest run --config vitest.live.config.ts",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "wrangler": "^4.107.0"
  }
}
