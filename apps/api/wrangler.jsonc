{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aboutyou-private-catalog-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-06",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "ALLOWED_ORIGIN": "https://aboutyou-private-catalog-web.pages.dev",
    "WEB_APP_URL": "https://aboutyou-private-catalog-web.pages.dev",
    "TELEGRAM_BOT_USERNAME": "AboutYouTrackerBot",
    "GITHUB_OWNER": "mokinys98",
    "GITHUB_REPO": "AboutYou",
    "GITHUB_REF": "main"
  },
  "triggers": {
    "crons": [
      "17 */6 * * *",
      "47 * * * *",
      "*/5 * * * *"
    ]
  },
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    }
  }
}
