{
  "name": "@catalog/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env-file ../../.env",
    "dev:real-db": "wrangler dev --env-file ../../.env --env-file ../../config/env/api-local.env",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "types": "wrangler types --include-runtime false",
    "typecheck": "wrangler types --include-runtime false --check && tsc --noEmit"
  },
  "dependencies": {
    "@catalog/shared": "*",
    "@supabase/supabase-js": "latest",
    "hono": "latest",
    "jose": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "latest",
    "typescript": "latest",
    "wrangler": "latest"
  }
}
