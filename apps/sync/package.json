{
  "name": "@catalog/sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "node --env-file-if-exists=../../.env --import tsx src/index.ts",
    "sync:metadata": "node --env-file-if-exists=../../.env --import tsx src/metadata.ts",
    "verify:catalog:staging": "node --env-file-if-exists=../../.env --import tsx src/verify-catalog-staging.ts",
    "archive:raw": "node --env-file-if-exists=../../.env --import tsx src/archive-existing-raw.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@catalog/aboutyou-provider": "*",
    "@catalog/shared": "*",
    "@supabase/supabase-js": "latest",
    "playwright": "latest",
    "zod": "latest"
  },
  "devDependencies": { "tsx": "latest", "typescript": "latest" }
}
